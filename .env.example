# Public-safe template for runtime configuration.
# Copy to ./.env (gitignored).
#
# Secrets:
# - Set SRCDS_TOKEN and SRCDS_RCONPW in this private file, OR
# - Leave them blank here and generate secret files with:
#   docker compose --profile setup run --rm secret-init

# Required secrets (set via secret files in secrets folder).
SRCDS_TOKEN=
SRCDS_RCONPW=

# CS:GO legacy dedicated server appid.
STEAM_APP_ID=4465480
# Set to 0 to skip Steam update on each container start.
UPDATE_ON_START=1
# Optional: leave blank to use anonymous login. Use secrets/steam_user + secrets/steam_pass for local-only auth.
STEAM_USER=
STEAM_PASS=
STEAM_GUARD_CODE=
# Default keeps password out of routine boots; uses cached Steam login/session instead.
USE_STEAM_PASSWORD_LOGIN=0
# Steam Linux Runtime (scout) app used to run csgo.sh when runtime wrapper is missing.
STEAM_RUNTIME_APP_ID=1070560

# Optional server password (blank = no password).
SRCDS_PW=

# Server identity and gameplay.
SRCDS_HOSTNAME=csgo server
SRCDS_MAXPLAYERS=12
SRCDS_PORT=27015
SRCDS_CLIENT_PORT=27005
SRCDS_TV_PORT=27020
SRCDS_STARTMAP=de_nuke
SRCDS_MAPGROUP=mg_active
SRCDS_GAMETYPE=0
SRCDS_GAMEMODE=1
TV_ENABLE=1
RETRY_ATTEMPTS=5

# FastDL listener on host. Keep sv_downloadurl in overrides.local/csgo/cfg/custom/02-access-security.cfg in sync.
FASTDL_PORT=8080
FASTDL_PUBLIC_URL=http://YOUR_PUBLIC_HOST:8080/csgo

# Plugin bootstrap behavior.
MMS_BRANCH=1.11
SM_BRANCH=1.11
FORCE_PLUGIN_REINSTALL=0
